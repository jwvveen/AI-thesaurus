      <element xsi:type="archimate:Grouping" name="Prompt Management" id="id-240af6a484e049c3bbe0c04693f45c8d"/>
      <element xsi:type="archimate:Grouping" name="Identity &amp; Access" id="id-28be6e1f41814053bff6945e951fd660"/>
      <element xsi:type="archimate:Grouping" name="Policy Engines" id="id-22d68a1c455748bda4925edbf7416e22"/>
      <element xsi:type="archimate:Grouping" name="MLOps &amp; Registry" id="id-5976f4b622d54f738d53d7f58739ed66"/>
      <element xsi:type="archimate:Grouping" name="API Gateways" id="id-6afa2359f4ea45c288fb079fcf99e519"/>
      <element xsi:type="archimate:Grouping" name="Monitoring" id="id-d404ee08d70845f7b1e16ba54635ee9a"/>
      <element xsi:type="archimate:Grouping" name="CI/CD &amp; Infra" id="id-ebff9c4e39804db9a93cd62c82ff080d"/>
      <element xsi:type="archimate:Grouping" name="Model Serving" id="id-5be99ede224d43a9aab868b800aab0d0"/>
      <element xsi:type="archimate:Grouping" name="Vector Databases" id="id-df48aedf984b4cc68fd625dd32dd2315"/>
      <element xsi:type="archimate:Grouping" name="Knowledge Graphs" id="id-e68d3e1faae14b47908b0868880ef44a"/>
      <element xsi:type="archimate:Grouping" name="Data Platforms" id="id-6c9ccea5c0dc489d8ef6748a03c0dac9"/>
      <element xsi:type="archimate:Grouping" name="Data Quality" id="id-ed7180679df24c50b573d44a475ce431"/>
      <element xsi:type="archimate:Grouping" name="Feature Stores" id="id-b002c24c5be44c1c8fbc65d7ce145881"/>
      <element xsi:type="archimate:Grouping" name="Annotation" id="id-4cbdd9bc3d234fc7a614ea9b2ff10fc2"/>
