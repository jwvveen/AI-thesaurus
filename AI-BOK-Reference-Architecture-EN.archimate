        <documentation>Authoritative concept framework (SKOS/NL-SBB) for AI systems.</documentation>
        <property key="gdpr-classification" value="No personal data"/>
        <property key="confidentiality" value="Public"/>
        <property key="dct:source" value="AI-BOK v1.0, Module 1, sectie 5.4, p.30"/>
      </element>
      <element xsi:type="archimate:Representation" name="Model Card" id="id-0dd320579ff444d7b187d5b668f13b64">
        <documentation>Standardised documentation of an AI model.</documentation>
        <property key="gdpr-classification" value="Possibly personal data (training data description)"/>
        <property key="confidentiality" value="Internal"/>
