      <element xsi:type="archimate:Contract" name="AI Policy Framework" id="id-9772b6efee7a49f6be4591b4a09b7927">
        <documentation>Organisation-wide AI policy with principles, roles and mandates.</documentation>
        <property key="gdpr-classification" value="No personal data"/>
        <property key="confidentiality" value="Internal"/>
        <property key="retention-period" value="Permanent"/>
