        <property key="governance-intensity" value="Very High"/>
        <property key="ai-act-risk-class" value="High"/>
        <property key="dct:source" value="AI-BOK v1.0, Module 1, sectie 9.1, p.30"/>
      </element>
      <element xsi:type="archimate:Capability" name="KA10: AI Compliance &amp; Audit" id="id-24905547f48b49cdaca39fb8f12312ea">
        <documentation>Verifiable, risk-based compliance of AI systems.</documentation>
        <property key="business-value" value="High"/>
        <property key="maturity-level" value="3-Defined"/>
        <property key="governance-intensity" value="Very High"/>
        <property key="ai-act-risk-class" value="High"/>
        <property key="dct:source" value="AI-BOK v1.0, Module 1, sectie 10.1, p.28"/>
      </element>
      <element xsi:type="archimate:Capability" name="KA11: AI Ethics &amp; Responsible AI" id="id-ddccd254aaa2436a9cb5e6f4ff83cd2d">
        <documentation>Ethical considerations structurally embedded in the design and deployment of AI.</documentation>
