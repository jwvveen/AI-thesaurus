        <property key="vendor-dependency" value="Open Source"/>
        <property key="deployment-model" value="On-premise"/>
        <property key="dct:source" value="AI-BOK v1.0, Module 3, sectie 3.6.5a, p.163"/>
      </element>
      <element xsi:type="archimate:ApplicationComponent" name="Explainability Engine" id="id-520e442dd4304a1da3172be5d08ecfcc">
        <documentation>Uitlegbaarheidsmechanismen voor AI-beslissingen: feature attribution, counterfactuals, attention maps.</documentation>
