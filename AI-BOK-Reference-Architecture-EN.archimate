        <property key="vendor-dependency" value="Commercial"/>
        <property key="deployment-model" value="On-premise / SaaS"/>
        <property key="integration-protocol" value="REST / gRPC / GraphQL"/>
        <property key="availability-sla" value="99,99%"/>
        <property key="dct:source" value="AI-BOK v1.0, Module 3, sectie 3.6.5a, p.163"/>
      </element>
      <element xsi:type="archimate:ApplicationComponent" name="Vector Database" id="id-d63d36fe484745f0b056b04576983feb">
        <documentation>Storage and similarity search of embeddings for RAG and semantic search.</documentation>
        <property key="lifecycle-phase" value="Current"/>
        <property key="plane" value="Data Plane"/>
        <property key="vendor-dependency" value="Commercial"/>
        <property key="deployment-model" value="SaaS / On-premise"/>
        <property key="integration-protocol" value="REST API / gRPC"/>
        <property key="availability-sla" value="99,9%"/>
        <property key="data-sensitivity" value="High (embeddings of business data)"/>
        <property key="dct:source" value="AI-BOK v1.0, Module 3, sectie 3.6.5a, p.163"/>
      </element>
      <element xsi:type="archimate:ApplicationComponent" name="Knowledge Graph" id="id-d1ff6f807fc44c08919e0c585e7f02f8">
        <documentation>Knowledge graph for structured knowledge: entities, relations, ontologies (RDF/OWL/SKOS).</documentation>
        <property key="lifecycle-phase" value="Current"/>
        <property key="plane" value="Data Plane"/>
        <property key="vendor-dependency" value="Open Source"/>
        <property key="deployment-model" value="On-premise"/>
        <property key="integration-protocol" value="SPARQL / REST API"/>
        <property key="availability-sla" value="99,9%"/>
        <property key="data-sensitivity" value="Medium (concepts and relationships)"/>
        <property key="dct:source" value="AI-BOK v1.0, Module 3, sectie 3.6.5a, p.163"/>
      </element>
      <element xsi:type="archimate:ApplicationComponent" name="Feature Store" id="id-e828a232398b442b9aed3f4073ac7c10">
        <documentation>Standardised storage and serving of ML features for training and inference.</documentation>
        <property key="lifecycle-phase" value="Current"/>
        <property key="plane" value="Data Plane"/>
        <property key="vendor-dependency" value="Open Source"/>
        <property key="deployment-model" value="On-premise"/>
        <property key="integration-protocol" value="REST API / gRPC"/>
        <property key="dct:source" value="AI-BOK v1.0, Module 3, sectie 3.6.5a, p.163"/>
      </element>
      <element xsi:type="archimate:ApplicationComponent" name="Data Lake/Warehouse" id="id-4a696716fb9c4fffbea68dbe49e9fd78">
        <documentation>Central storage for training data, evaluation data and analytics.</documentation>
        <property key="lifecycle-phase" value="Current"/>
