      <element xsi:type="archimate:ApplicationComponent" name="Model Serving" id="id-23bbfd9d8da6481daad50d6aa7adbfdf">
        <documentation>Production-serving van ML-modellen: batching, caching, GPU-optimalisatie, A/B-testing.</documentation>
        <property key="lifecycle-phase" value="Current"/>
        <property key="plane" value="Control Plane"/>
        <property key="vendor-dependency" value="Open Source"/>
