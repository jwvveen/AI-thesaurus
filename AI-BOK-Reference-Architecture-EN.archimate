      </element>
      <element xsi:type="archimate:ApplicationComponent" name="Monitoring &amp; Observability" id="id-ec8ad5d9664243e6a18c51c64c191f4f">
        <documentation>Continuous monitoring of AI systems: performance, costs, drift, anomalies and SLA monitoring.</documentation>
        <property key="lifecycle-phase" value="Current"/>
