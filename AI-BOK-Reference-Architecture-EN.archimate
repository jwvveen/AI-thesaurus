        <property key="maturity-level" value="2-Repeatable"/>
        <property key="governance-intensity" value="High"/>
        <property key="ai-act-risk-class" value="High"/>
        <property key="dct:source" value="AI-BOK v1.0, Module 1, sectie 11.1, p.34"/>
      </element>
      <element xsi:type="archimate:Capability" name="KA12: AI Knowledge &amp; Context Management" id="id-ab42f8a74b4f4c74960a43558a6f4b3e">
        <documentation>AI systems produce grounded, traceable and semantically vamemberated output.</documentation>
        <property key="business-value" value="Very High"/>
        <property key="maturity-level" value="3-Defined"/>
        <property key="governance-intensity" value="High"/>
        <property key="ai-act-risk-class" value="High"/>
        <property key="dct:source" value="AI-BOK v1.0, Module 1, sectie 12.1, p.34"/>
      </element>
    </folder>
    <folder name="ValueStream" id="id-0c30a848b0be4ef1bd3e6a29c48bb43a">
      <element xsi:type="archimate:ValueStream" name="Idee &amp; Kans" id="id-d1a8621fd4bb423b8ee16b248b021a4b">
        <documentation>Identify AI opportunities and assess business value.</documentation>
      </element>
      <element xsi:type="archimate:ValueStream" name="Design" id="id-e99b8d4302cd469e803dac4c43195645">
        <documentation>Architecture, data preparation and model selection.</documentation>
      </element>
      <element xsi:type="archimate:ValueStream" name="Development" id="id-5935497580e346de975cc3574f55de80">
        <documentation>Training, fine-tuning, prompt engineering and evaluation.</documentation>
      </element>
      <element xsi:type="archimate:ValueStream" name="Production" id="id-c3e6d01388b7460ea859bc91e2c15b78">
        <documentation>Deployment, integration, monitoring and operations.</documentation>
      </element>
      <element xsi:type="archimate:ValueStream" name="Value" id="id-38ff22bfe63d4cf7b357deae44395481">
        <documentation>Measurable business value and continuous improvement.</documentation>
      </element>
    </folder>
  </folder>
