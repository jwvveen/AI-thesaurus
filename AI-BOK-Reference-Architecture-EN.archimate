        <property key="vendor-dependency" value="Open Source"/>
        <property key="deployment-model" value="SaaS / On-premise"/>
        <property key="integration-protocol" value="OpenTelemetry / Prometheus"/>
        <property key="availability-sla" value="99,99%"/>
        <property key="dct:source" value="AI-BOK v1.0, Module 3, sectie 3.6.5a, p.163"/>
      </element>
      <element xsi:type="archimate:ApplicationComponent" name="Bias Detection &amp; Fairness" id="id-fbce5dedd79b4c179ca497c5ca23fb2d">
        <documentation>Detection and mitigation of bias in models and data. Fairness metrics and debiasing techniques.</documentation>
        <property key="lifecycle-phase" value="Current"/>
