        <property key="dct:source" value="AI-BOK v1.0, Module 3, sectie 3.1.7, p.127"/>
      </element>
    </folder>
  </folder>
  <folder name="Application" id="id-da5fa5a698c7479b803158ab2ba7d694" type="application">
    <folder name="Data Objects (Meta-model)" id="id-f9233bfe0dcc424c8e3a24dbb234cb6c">
