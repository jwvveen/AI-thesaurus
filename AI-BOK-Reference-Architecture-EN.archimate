    <folder name="Representation" id="id-78ac1598ce21429c9ee99db0609bb732">
      <element xsi:type="archimate:Representation" name="AI Reference Architecture" id="id-04be5ca6dca14a71888310d0c9fc5869">
        <documentation>Blueprint for AI capabilities including Cognition Plane.</documentation>
        <property key="gdpr-classification" value="No personal data"/>
        <property key="confidentiality" value="Internal"/>
        <property key="retention-period" value="Permanent"/>
        <property key="dct:source" value="AI-BOK v1.0, Module 1, sectie 3.4, p.22"/>
      </element>
