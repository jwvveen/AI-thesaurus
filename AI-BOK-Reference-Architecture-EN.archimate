        <property key="dct:source" value="AI-BOK v1.0, Module 3, sectie 3.1.2, p.122"/>
      </element>
      <element xsi:type="archimate:BusinessEvent" name="Gate: Data Readiness" id="id-7d2788e75cfa4b7bad6670ad259c3570">
        <property key="dct:source" value="AI-BOK v1.0, Module 3, sectie 3.1.3, p.123"/>
      </element>
      <element xsi:type="archimate:BusinessEvent" name="Gate: Model Validated" id="id-eb8de4c36e1349b7ae4276630f5d80bf">
        <property key="dct:source" value="AI-BOK v1.0, Module 3, sectie 3.1.4, p.124"/>
      </element>
      <element xsi:type="archimate:BusinessEvent" name="Gate: Production Ready" id="id-a8bd85513b1f48c28e3ca64972a6f5a1">
        <property key="dct:source" value="AI-BOK v1.0, Module 3, sectie 3.1.5, p.125"/>
