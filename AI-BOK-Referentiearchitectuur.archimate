      </element>
      <element xsi:type="archimate:BusinessFunction" name="AI Ethiek &amp; Verantwoording" id="id-77f9eb4b44634f35a0b525370a628214">
        <documentation>Borgen van ethische principes in AI-systemen.</documentation>
        <property key="business-value" value="High"/>
