      </element>
      <element xsi:type="archimate:BusinessFunction" name="AI Interactiebeheer" id="id-4e2da58ea10649c08804feb42d53b860">
        <documentation>Ontwerp en optimalisatie van AI-gebruikersinteracties.</documentation>
