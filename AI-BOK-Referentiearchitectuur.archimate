        <documentation>Deployment, monitoring en operationele betrouwbaarheid.</documentation>
        <property key="business-value" value="High"/>
        <property key="dct:source" value="AI-BOK v1.0, Module 1, sectie 8.3, p.26"/>
      </element>
      <element xsi:type="archimate:BusinessFunction" name="AI Risicobeheer" id="id-5db7e17639d9474787b8ae43a5180a06">
