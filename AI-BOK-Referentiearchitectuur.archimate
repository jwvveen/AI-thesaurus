        <property key="cost-indication" value="Free"/>
        <property key="dct:source" value="AI-BOK v1.0, Module 3, sectie 3.6.5a, p.163"/>
      </element>
      <element xsi:type="archimate:Node" name="Helm Charts" id="id-f3aeec9b6e0845988a8f684dda641d19">
