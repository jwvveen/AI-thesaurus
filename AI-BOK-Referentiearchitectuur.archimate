      <element xsi:type="archimate:BusinessFunction" name="AI Modelbeheer" id="id-3966dd11ea9e4803865b566abdbb9a3d">
        <documentation>Registratie, validatie en versiebeheer van AI-modellen.</documentation>
        <property key="business-value" value="Very High"/>
