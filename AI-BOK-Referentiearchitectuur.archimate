        <property key="dct:source" value="AI-BOK v1.0, Module 3, sectie 3.6.5a, p.163"/>
      </element>
      <element xsi:type="archimate:Node" name="Azure DevOps" id="id-7e046acdbf1447e3a5c5ff3418ba4873">
        <property key="dct:source" value="AI-BOK v1.0, Module 3, sectie 3.6.5a, p.163"/>
      </element>
      <element xsi:type="archimate:Node" name="Jenkins" id="id-982a0c7d77dc417a918b8a4c59dc8cc8">
