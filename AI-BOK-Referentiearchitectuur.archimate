        <property key="maturity-level" value="3-Gedefinieerd"/>
        <property key="governance-intensity" value="Very High"/>
        <property key="ai-act-risk-class" value="High"/>
        <property key="dct:source" value="AI-BOK v1.0, Module 1, sectie 1.1, p.7"/>
      </element>
      <element xsi:type="archimate:Capability" name="KG2: AI Strategie &amp; Portfoliomanagement" id="id-ef1dda39fa9b4ef0a3be8744ca014e93">
