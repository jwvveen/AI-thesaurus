      <element xsi:type="archimate:BusinessFunction" name="AI Architectuurbeheer" id="id-ca486cd67cfa4b2595ba871e422c8431">
        <documentation>Ontwerpen en onderhouden van de AI-referentiearchitectuur.</documentation>
        <property key="business-value" value="Very High"/>
