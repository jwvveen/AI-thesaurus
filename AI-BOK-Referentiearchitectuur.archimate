        <property key="dct:source" value="AI-BOK v1.0, Module 3, sectie 3.6.5a, p.163"/>
      </element>
      <element xsi:type="archimate:Node" name="Pulumi" id="id-835346b67e56448d859f2c17bbe05a15">
        <property key="lifecycle-phase" value="Planned"/>
        <property key="dct:source" value="AI-BOK v1.0, Module 3, sectie 3.6.5a, p.163"/>
      </element>
      <element xsi:type="archimate:Node" name="TriplyDB" id="id-a32de6d7240341c9a2da0d7bbbf57c1a">
